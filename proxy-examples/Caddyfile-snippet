# Jodi VPS e age theke Caddy chole, tahole tomar main Caddyfile e
# ei block ta jog koro (Caddy nijei SSL niye nebe), tarpor:  caddy reload

save.hunterflow.cloud {
	encode gzip

	reverse_proxy 127.0.0.1:8080 {
		transport http {
			read_timeout 1800s
			write_timeout 1800s
			dial_timeout 30s
		}
	}

	request_body {
		max_size 0
	}
}
