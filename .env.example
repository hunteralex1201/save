# ===== Ei file ke ".env" name e copy kore tomar value boshao =====
# cp .env.example .env   tarpor edit koro

# Tomar subdomain (DNS A record ei VPS er IP te point korano thakte hobe)
DOMAIN=dl.tomarsite.com

# Let's Encrypt SSL certificate er jonno tomar email
EMAIL=tomar@email.com

# Server password (Shortcut e ?key=... e ei value debe).
# Ekta lomba random string dao. Bananor jonno:  openssl rand -hex 24
DL_KEY=ekhane-lomba-random-secret-boshao

# Ek shathe koto download cholbe
MAX_CONCURRENT=3

# Download koto second por server theke muche jabe
MAX_FILE_AGE=3600
